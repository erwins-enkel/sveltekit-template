# Neon Postgres (auto-injected by the Vercel Marketplace Neon integration)
DATABASE_URL=

# Public URL of this deployment — use for OAuth redirect URIs etc.
APP_URL=http://localhost:5173

# 32+ byte random hex; use for cookie + secret-column encryption
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Sentry error tracking. Optional — leave PUBLIC_SENTRY_DSN empty to disable
# (the SDK initializes as a no-op). Find the DSN in Sentry → Project Settings.
PUBLIC_SENTRY_DSN=

# Build-time only: uncomment to upload source maps to Sentry on deploy.
# Without SENTRY_AUTH_TOKEN the build skips upload entirely.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- Uncomment when you add auth/email (see README) -------------------------
# BetterAuth — `openssl rand -hex 32` for the secret; URL is this deployment.
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:5173
# Resend transactional email.
# RESEND_API_KEY=
